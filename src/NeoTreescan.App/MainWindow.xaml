<Window x:Class="NeoTreescan.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:NeoTreescan.App.Converters"
        xmlns:ctrl="clr-namespace:NeoTreescan.App.Controls"
        xmlns:vm="clr-namespace:NeoTreescan.App.ViewModels"
        Title="NeoTreescan" Height="780" Width="1280" MinWidth="820" MinHeight="520"
        Icon="pack://application:,,,/Resources/NeoTreescan.ico"
        Background="#FF161618" Foreground="#FFE8E8EC" FontFamily="Segoe UI" FontSize="13"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Window.Resources>
        <conv:ByteSizeConverter x:Key="ByteSize"/>
        <conv:PercentConverter  x:Key="Pct"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="Bg"        Color="#FF161618"/>
        <SolidColorBrush x:Key="Panel"     Color="#FF1E1E22"/>
        <SolidColorBrush x:Key="Panel2"    Color="#FF242428"/>
        <SolidColorBrush x:Key="Border"    Color="#FF32323A"/>
        <SolidColorBrush x:Key="BorderHi"  Color="#FF4A4A54"/>
        <SolidColorBrush x:Key="Text"      Color="#FFE8E8EC"/>
        <SolidColorBrush x:Key="Subtle"    Color="#FFA0A0AA"/>
        <SolidColorBrush x:Key="Faint"     Color="#FF6B6B76"/>
        <SolidColorBrush x:Key="Accent"    Color="#FF4C9AFF"/>
        <SolidColorBrush x:Key="AccentHi"  Color="#FF6AB0FF"/>
        <SolidColorBrush x:Key="AccentDim" Color="#FF2A4A7A"/>
        <SolidColorBrush x:Key="Good"      Color="#FF3BAA5C"/>
        <FontFamily x:Key="Icons">Segoe Fluent Icons,Segoe MDL2 Assets</FontFamily>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Panel2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin"  Value="0,0,6,0"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF2F2F36"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderHi}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3A3A42"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Faint}"/>
                                <Setter TargetName="bd" Property="Background" Value="#FF1A1A1E"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF2A2A30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHi}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHi}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CrumbButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource Subtle}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Panel2}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Panel2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Tab styling -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource Subtle}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}" TextBlock.FontSize="13"/>
                                <Border x:Name="underline" Height="2" VerticalAlignment="Bottom" Margin="0,0,0,-1"
                                        Background="{StaticResource Accent}" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                <Setter TargetName="underline" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <TabPanel x:Name="HeaderPanel" IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <Border Background="{StaticResource Bg}">
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                            </Border>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin themed scrollbar (vertical + horizontal) -->
        <Style x:Key="ThinScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="tb" Background="#FF3A3A44" CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="#FF55555F"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="#FF6C6C78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ThinScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource Bg}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#FF1B1B1F"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FF242428"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="26"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="Foreground" Value="{StaticResource Subtle}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <!-- TreeView -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,6"/>
        </Style>

        <!-- Tree item with hover + selection -->
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  ClickMode="Press" Focusable="False" Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <Path x:Name="arrow" Data="M 0 0 L 4 4 L 0 8 Z" Fill="#FF888893" Margin="4,4,0,0"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="arrow" Property="Data" Value="M 0 0 L 8 0 L 4 5 Z"/>
                                                        <Setter TargetName="arrow" Property="Fill" Value="#FFAAAAB4"/>
                                                        <Setter TargetName="arrow" Property="Margin" Value="2,6,0,0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="12,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True" SourceName="bd">
                                <Setter TargetName="bd" Property="Background" Value="#FF202026"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDim}"/>
                                <Setter TargetName="bd" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stats card template -->
        <Style x:Key="StatBox" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ScanCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding BrowseFolderCommand}"/>
        <KeyBinding Modifiers="Control" Key="E" Command="{Binding ExportExcelCommand}"/>
        <KeyBinding Modifiers="Control" Key="L" Command="{Binding FocusPathCommand}"/>
    </Window.InputBindings>

    <DockPanel LastChildFill="True">
        <!-- Toolbar: DockPanel so path box flexes with window width -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="14,10">
            <DockPanel LastChildFill="True">
                <!-- Brand (left, fixed) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border Width="32" Height="32" Background="{StaticResource Accent}" CornerRadius="7" Margin="0,0,10,0">
                        <Grid>
                            <Ellipse Width="16" Height="16" Stroke="White" StrokeThickness="1.8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Path Data="M 0 0 L 7 0 L 0 7 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding BrandName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                        <TextBlock Text="{Binding BrandTagline}" FontSize="10.5" Foreground="{StaticResource Faint}" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions (right, fixed). Declared Dock=Right in order so they hug the right edge. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding ScanCommand}" ToolTip="Start scan (F5)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE773;" FontFamily="{StaticResource Icons}" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Scan"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding CancelCommand}" ToolTip="Cancel scan (Esc)">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource Icons}" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ExportExcelCommand}" ToolTip="Export to .xlsx (Ctrl+E)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource Icons}" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Export"/>
                        </StackPanel>
                    </Button>
                    <CheckBox Content="Fast path" IsChecked="{Binding UseFastPath}" Margin="12,0,8,0"
                              ToolTip="Use NTFS MFT scan when available (admin + local NTFS)"/>
                    <Border CornerRadius="12" Background="#FF1F3B23" BorderBrush="#FF3D7A47" BorderThickness="1"
                            Padding="10,3" VerticalAlignment="Center"
                            Visibility="{Binding IsAdministrator, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7EF;" FontFamily="{StaticResource Icons}" FontSize="12" Foreground="#FF5CC88A" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Admin" Foreground="#FF9FE0B2" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RestartAsAdminCommand}"
                            ToolTip="Relaunch with Administrator privileges for full disk access"
                            Visibility="{Binding IsNotAdministrator, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7EF;" FontFamily="{StaticResource Icons}" FontSize="14" Foreground="#FFF2A34C" Margin="0,0,6,0"/>
                            <TextBlock Text="Admin" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ShowAboutCommand}" ToolTip="About">
                        <TextBlock Text="&#xE946;" FontFamily="{StaticResource Icons}" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- Path + Browse (fills remaining space) -->
                <DockPanel LastChildFill="True" VerticalAlignment="Center">
                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Command="{Binding BrowseFolderCommand}"
                            ToolTip="Browse (Ctrl+O)" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED25;" FontFamily="{StaticResource Icons}" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Browse"/>
                        </StackPanel>
                    </Button>
                    <TextBox x:Name="PathBox" Text="{Binding RootPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             ToolTip="Type a path, click Browse, or drop a folder here (Ctrl+L to focus)"/>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource Faint}" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Run Text="{Binding BrandName, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding BrandCompany, Mode=OneWay}"/>
                    </TextBlock>
                    <Border Width="1" Height="12" Background="{StaticResource Border}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" Foreground="{StaticResource Subtle}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalsText}" Foreground="{StaticResource Text}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Foreground="{StaticResource Faint}" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Run Text="&#xE9A9;" FontFamily="{StaticResource Icons}" FontSize="11"/>
                        <Run Text=" "/>
                        <Run Text="{Binding ScannerUsed, Mode=OneWay}"/>
                    </TextBlock>
                    <ProgressBar Width="140" Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressBytes}"
                                 Foreground="{StaticResource Accent}" Background="{StaticResource Panel2}" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main split: tree | right pane (star-sized so both panes flex with window) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="3*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: folder tree -->
            <Border Grid.Column="0" Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="14,10,14,8" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FOLDER" Foreground="{StaticResource Faint}" FontSize="11" FontWeight="SemiBold" Grid.Column="0"/>
                            <TextBlock Text="SIZE" Foreground="{StaticResource Faint}" FontSize="11" FontWeight="SemiBold" Width="80" TextAlignment="Right" Margin="0,0,10,0" Grid.Column="1"/>
                            <TextBlock Text="% PARENT" Foreground="{StaticResource Faint}" FontSize="11" FontWeight="SemiBold" Width="70" Grid.Column="2" Margin="0,0,10,0"/>
                            <TextBlock Text="FILES" Foreground="{StaticResource Faint}" FontSize="11" FontWeight="SemiBold" Width="60" TextAlignment="Right" Grid.Column="3"/>
                        </Grid>
                    </Border>
                    <TreeView x:Name="Tree" ItemsSource="{Binding RootNodes}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              SelectedItemChanged="Tree_SelectedItemChanged"
                              ItemContainerStyle="{StaticResource TreeItemStyle}">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FolderNodeViewModel}" ItemsSource="{Binding Children}">
                                <Grid Height="22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource Icons}" FontSize="13"
                                                   Foreground="{StaticResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalSize, Converter={StaticResource ByteSize}}"
                                               Width="80" TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"
                                               FontFamily="Consolas, Segoe UI"/>
                                    <Border Grid.Column="2" Width="70" Height="6" Margin="0,0,10,0" VerticalAlignment="Center"
                                            Background="{StaticResource Panel2}" CornerRadius="3">
                                        <Border Background="{StaticResource Accent}" HorizontalAlignment="Left" CornerRadius="3"
                                                Width="{Binding PercentOfParent, Converter={StaticResource Pct}, ConverterParameter=70}"/>
                                    </Border>
                                    <TextBlock Grid.Column="3" Text="{Binding TotalFileCount, StringFormat=N0}"
                                               Width="60" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource Subtle}"
                                               FontFamily="Consolas, Segoe UI"/>
                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ContextMenu>
                            <ContextMenu Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" Foreground="{StaticResource Text}">
                                <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE838;" FontFamily="{StaticResource Icons}" FontSize="13"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Copy path" Click="CopyPath_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource Icons}" FontSize="13"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Set as scan root" Click="SetAsRoot_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE773;" FontFamily="{StaticResource Icons}" FontSize="13"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Focus on treemap" Click="FocusTreemap_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8A9;" FontFamily="{StaticResource Icons}" FontSize="13"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1,0"/>

            <!-- RIGHT -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Selection detail strip -->
                <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,14">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                                <TextBlock Text="SIZE" Foreground="{StaticResource Faint}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedNode.TotalSize, Converter={StaticResource ByteSize}, FallbackValue='-'}" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                                <TextBlock Text="FILES" Foreground="{StaticResource Faint}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedNode.TotalFileCount, StringFormat=N0, FallbackValue='-'}" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="FOLDERS" Foreground="{StaticResource Faint}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedNode.TotalFolderCount, StringFormat=N0, FallbackValue='-'}" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource Icons}" FontSize="18" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedNode.Name, FallbackValue='No selection'}" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedNode.FullPath, FallbackValue='-'}" Foreground="{StaticResource Faint}" FontSize="11" FontFamily="Consolas, Segoe UI" Margin="26,2,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Tabs -->
                <TabControl Grid.Row="1">
                    <TabItem Header="Treemap">
                        <DockPanel>
                            <!-- Breadcrumb -->
                            <Border DockPanel.Dock="Top" Padding="10,6" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Background="{StaticResource Panel}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72B;" FontFamily="{StaticResource Icons}" FontSize="12" Foreground="{StaticResource Faint}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <ItemsControl ItemsSource="{Binding Breadcrumb}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource CrumbButton}" Content="{Binding Label}"
                                                            Command="{Binding DataContext.NavigateToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Node}"/>
                                                    <TextBlock Text="›" Foreground="{StaticResource Faint}" Margin="2,0" VerticalAlignment="Center"
                                                               Visibility="{Binding HasMore, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <ctrl:TreemapControl x:Name="Treemap" Root="{Binding SelectedNode.Model, FallbackValue={x:Null}}" Margin="8" NodeClicked="Treemap_NodeClicked"/>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="File Types">
                        <DataGrid ItemsSource="{Binding FileTypes}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="140"/>
                                <DataGridTextColumn Header="Files" Binding="{Binding FileCount, StringFormat=N0}" Width="100"/>
                                <DataGridTextColumn Header="Size"  Binding="{Binding TotalSize, Converter={StaticResource ByteSize}}" Width="130"/>
                                <DataGridTemplateColumn Header="Distribution" Width="*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Height="8" VerticalAlignment="Center" Background="{StaticResource Panel2}" CornerRadius="3" Margin="6,0,14,0">
                                                <Border Background="{StaticResource Accent}" HorizontalAlignment="Left" CornerRadius="3"
                                                        Width="{Binding BarPercent, Converter={StaticResource Pct}, ConverterParameter=240}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="File Ages">
                        <DataGrid ItemsSource="{Binding AgeBuckets}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Age" Binding="{Binding Label}" Width="200"/>
                                <DataGridTextColumn Header="Files" Binding="{Binding FileCount, StringFormat=N0}" Width="120"/>
                                <DataGridTextColumn Header="Size"  Binding="{Binding TotalSize, Converter={StaticResource ByteSize}}" Width="140"/>
                                <DataGridTemplateColumn Header="Distribution" Width="*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Height="8" VerticalAlignment="Center" Background="{StaticResource Panel2}" CornerRadius="3" Margin="6,0,14,0">
                                                <Border Background="#FFF2A34C" HorizontalAlignment="Left" CornerRadius="3"
                                                        Width="{Binding BarPercent, Converter={StaticResource Pct}, ConverterParameter=240}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="File Sizes">
                        <DataGrid ItemsSource="{Binding SizeBuckets}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Size Bucket" Binding="{Binding Label}" Width="200"/>
                                <DataGridTextColumn Header="Files" Binding="{Binding FileCount, StringFormat=N0}" Width="120"/>
                                <DataGridTextColumn Header="Size"  Binding="{Binding TotalSize, Converter={StaticResource ByteSize}}" Width="140"/>
                                <DataGridTemplateColumn Header="Distribution" Width="*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Height="8" VerticalAlignment="Center" Background="{StaticResource Panel2}" CornerRadius="3" Margin="6,0,14,0">
                                                <Border Background="#FF5CC88A" HorizontalAlignment="Left" CornerRadius="3"
                                                        Width="{Binding BarPercent, Converter={StaticResource Pct}, ConverterParameter=240}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Top Files">
                        <DataGrid ItemsSource="{Binding TopFiles}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding Size, Converter={StaticResource ByteSize}}" Width="120"/>
                                <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="100"/>
                                <DataGridTextColumn Header="Modified (UTC)" Binding="{Binding LastWriteUtc, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
