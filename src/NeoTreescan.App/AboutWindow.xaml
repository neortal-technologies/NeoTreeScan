<Window x:Class="NeoTreescan.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NeoTreescan.App"
        Title="About NeoTreescan" Height="620" Width="540"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="460" MinHeight="500"
        Icon="pack://application:,,,/Resources/NeoTreescan.ico"
        Background="#FF161618" Foreground="#FFE8E8EC" FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <FontFamily x:Key="Icons">Segoe Fluent Icons,Segoe MDL2 Assets</FontFamily>
        <SolidColorBrush x:Key="Subtle"   Color="#FFA0A0AA"/>
        <SolidColorBrush x:Key="Faint"    Color="#FF6B6B76"/>
        <SolidColorBrush x:Key="Accent"   Color="#FF4C9AFF"/>
        <SolidColorBrush x:Key="Panel"    Color="#FF1E1E22"/>
        <SolidColorBrush x:Key="Panel2"   Color="#FF242428"/>
        <SolidColorBrush x:Key="Border"   Color="#FF32323A"/>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>
    </Window.Resources>
    <DockPanel LastChildFill="True">
        <!-- Footer with Close button -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="16,10">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" x:Name="CopyrightText" Foreground="{StaticResource Faint}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <Button DockPanel.Dock="Right" Content="Close" Width="90" Height="30" Click="Close_Click" Background="{StaticResource Accent}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </DockPanel>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,24,28,20">
                <!-- Header -->
                <StackPanel Orientation="Horizontal">
                    <Border Width="56" Height="56" Background="{StaticResource Accent}" CornerRadius="12" Margin="0,0,16,0">
                        <Grid>
                            <Ellipse Width="28" Height="28" Stroke="White" StrokeThickness="2.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Path Data="M 0 0 L 12 0 L 0 12 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="ProductText" Text="NeoTreescan" FontSize="24" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock x:Name="TaglineText" Text="Disk space analyzer" Foreground="{StaticResource Subtle}" FontSize="13" VerticalAlignment="Center"/>
                            <Border Style="{StaticResource Pill}" Background="#FF1B2A40" BorderBrush="#FF2F4F80" Margin="10,0,0,0">
                                <TextBlock x:Name="VersionPill" Text="v1.0.0" Foreground="#FF88B4FF" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Description -->
                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Foreground="{StaticResource Subtle}" FontSize="12.5" LineHeight="19" Margin="0,18,0,0"/>

                <!-- Section: Build -->
                <TextBlock Text="BUILD" Foreground="{StaticResource Faint}" FontSize="10.5" FontWeight="SemiBold" Margin="0,22,0,6"/>
                <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="14,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <TextBlock x:Name="VersionText" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Runtime" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <TextBlock x:Name="RuntimeText" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Architecture" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <TextBlock x:Name="ArchText" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="OS" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <TextBlock x:Name="OsText" Grid.Column="1"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Privilege" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="PrivilegeIcon" Text="&#xE7EF;" FontFamily="{StaticResource Icons}" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="PrivilegeText"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section: Publisher -->
                <TextBlock Text="PUBLISHER" Foreground="{StaticResource Faint}" FontSize="10.5" FontWeight="SemiBold" Margin="0,18,0,6"/>
                <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="14,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Company" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <TextBlock x:Name="CompanyText" Grid.Column="1" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Website" Foreground="{StaticResource Subtle}" Grid.Column="0"/>
                            <TextBlock Grid.Column="1">
                                <Hyperlink x:Name="WebsiteLink" Foreground="{StaticResource Accent}" Click="WebsiteLink_Click"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section: License -->
                <TextBlock Text="LICENSE" Foreground="{StaticResource Faint}" FontSize="10.5" FontWeight="SemiBold" Margin="0,18,0,6"/>
                <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="14,10">
                    <TextBlock x:Name="LicenseText" TextWrapping="Wrap" Foreground="{StaticResource Subtle}" FontSize="12" LineHeight="18"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
